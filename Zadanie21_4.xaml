<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadania.Zadanie21_4"
             Title="Zadanie21_4">
    <VerticalStackLayout>
        <Entry
            x:Name="NameEntry"
            Placeholder="Imię:"
            FontSize="18"
            MaxLength="100"/>
        <Entry
            x:Name="EmailEntry"
            Placeholder="E-Mail:"
            FontSize="18"
            Keyboard="Email"/>

        <Picker Title="Temat"
                x:Name="subjectPicker"
                SelectedIndexChanged="setPriorityPicker"
                >
            <Picker.Items>
                <x:String>Reklamacja</x:String>
                <x:String>Podziękowanie</x:String>
                <x:String>Pytanie</x:String>
                <x:String>Inne</x:String>
            </Picker.Items>
        </Picker>
        <Editor
            x:Name="MessageEditor"
            Placeholder="Wpisz swoją wiadomość"
            FontSize="18"
            MaxLength="1000"
            AutoSize="TextChanges"/>
        <Picker Title="Priorytet"
                x:Name="PriorityPicker">
            <Picker.Items>
                <x:String>Wysoki</x:String>
                <x:String>Średni</x:String>
                <x:String>Niski</x:String>
            </Picker.Items>
        </Picker>
        <HorizontalStackLayout
            VerticalOptions="Center">
            <CheckBox VerticalOptions="Center"/>
            <Label
            VerticalOptions="Center"
            Text="Wyślij mi kopię wiadomości na E-Mail"/>
        </HorizontalStackLayout>
        <Button
            Text="Wyślij"
            Clicked="checkIfCorrectAndSend"/>
    </VerticalStackLayout>
</ContentPage>