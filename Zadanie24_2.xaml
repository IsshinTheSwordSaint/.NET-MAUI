<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadania.Zadanie24_2"
             Title="Zadanie24_2">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Editor
            FontSize="17"
            x:Name="Pole"
        />
        <Button
        Text="Dodaj wpis"
        x:Name="Add"
        Clicked="AddLineClicked"
        />
        <Button
        Text="Wyczyść dziennik"
        x:Name="Delete"
        Clicked="DelLineClicked"
        />
        <ScrollView>
        <Label
            x:Name="DziennikLabel"
            HorizontalOptions="Fill"
        />
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>