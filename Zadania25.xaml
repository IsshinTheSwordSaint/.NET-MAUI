<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadania.Zadania25"
             Title="Zadania25">
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <HorizontalStackLayout>
                <Label 
                   Text="Temperatura:"
                   TextColor="Gray" FontSize="14" />
                <Label 
                    x:Name="LabelTemperature"
                    Text="—"
                    FontSize="14" FontAttributes="Bold" />
            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label 
                    Text="Wiatr:"
                    TextColor="Gray" FontSize="14" />
                <Label 
                    x:Name="LabelWind"
                    Text="—"
                    FontSize="14"
                    FontAttributes="Bold" />
            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label 
                   Text="Czas pomiaru:"
                   TextColor="Gray" FontSize="14" />
                <Label x:Name="LabelWeatherTime"
                   Text="—"
                   FontSize="14" />
            </HorizontalStackLayout>



            <HorizontalStackLayout Spacing="50">

                <Label 
               Text=" USD" FontSize="14" />
                <Label Grid.Row="1" Grid.Column="1"
               x:Name="LabelUSD"
               Text="—" FontSize="14" FontAttributes="Bold" />
                <Label 
               x:Name="LabelUSDDate"
               Text="—" FontSize="13" TextColor="Gray" />

            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="50">

                <Label 
               Text=" EUR" FontSize="14" />
                <Label 
               x:Name="LabelEUR"
               Text="—" FontSize="14" FontAttributes="Bold" />
                <Label Grid.Row="2" Grid.Column="2"
               x:Name="LabelEURDate"
               Text="—" FontSize="13" TextColor="Gray" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="50">

                <Label
               Text="GBP" FontSize="14" />
                <Label 
               x:Name="LabelGBP"
               Text="—" FontSize="14" FontAttributes="Bold" />
                <Label 
               x:Name="LabelGBPDate"
               Text="—" FontSize="13" TextColor="Gray" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="50">

                <Label 
               Text="CHF" FontSize="14" />
                <Label
               x:Name="LabelCHF"
               Text="—" FontSize="14" FontAttributes="Bold" />
                <Label 
               x:Name="LabelCHFDate"
               Text="—" FontSize="13" TextColor="Gray" />
            </HorizontalStackLayout>

            <Label x:Name="LabelCurrencyError"
       TextColor="Red"
       IsVisible="False"
       FontAttributes="Bold"
       FontSize="14" />

            <Label x:Name="LabelLastRefresh"
       Text="Ostatnia aktualizacja: —"
       FontSize="12"
       TextColor="Gray" />
            <Label x:Name="LabelWeatherError"
         Text=""
         TextColor="Red"
         FontSize="13"
         IsVisible="False" />
            <Button
                Text="Pokaż kurs walut" 
                Clicked="OnGetCurrencyClicked" />
            <Button
                Text="Pokaż pogode"
                Clicked="OnGetWeatherClicked"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>