<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadania.Zadanie24_1"
             Title="Zadanie24_1">
    <VerticalStackLayout>
        <Entry
            x:Name="Tekst"
        />
        <Button
            Text="Zapisz do pliku"
            Clicked="OnSaveClicked"/>
        <Button
            Text="Odczytaj z pliku"
            Clicked="OnLoadClicked"
            />
        <Label
            x:Name="Miejsce"
            FontAttributes="Bold"
            FontSize="Medium"
            />
    </VerticalStackLayout>
</ContentPage>